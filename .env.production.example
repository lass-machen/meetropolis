# ============================================================
# Meetropolis production .env template — for docker-compose.prod.yml
#
# Copy this file to `.env` next to docker-compose.prod.yml on the
# deploy host, fill in the values, then run:
#   docker compose -f docker-compose.prod.yml build --no-cache
#   docker compose -f docker-compose.prod.yml up -d
#
# For a quick local-dev .env see `.env.example` instead.
# ============================================================

# ─── Runtime ──────────────────────────────────────────────
NODE_ENV=production
TRUST_PROXY=true
COOKIE_SECURE=true

# ─── Postgres (Container + App share password) ────────────
# Pick a strong password BEFORE the first `up -d`. Once the DB
# volume is initialised, rotating the password requires either
# wiping the volume or running `ALTER USER postgres WITH PASSWORD …`
# inside the running container before bumping these values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__
POSTGRES_DB=meetropolis
DATABASE_URL=postgresql://postgres:__GENERATE_STRONG_PASSWORD__@db:5432/meetropolis?schema=public

# ─── Server secrets (Pflicht, kein DB-Fallback) ───────────
# Rotation invalidates all sessions / API tokens. Generate with:
#   openssl rand -hex 32   /   openssl rand -hex 16
JWT_SECRET=__REPLACE_ME_JWT_SECRET_32_BYTES_HEX__
API_TOKEN_PEPPER=__REPLACE_ME_API_TOKEN_PEPPER_16_BYTES_HEX__

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.example,tauri://localhost

# ─── LiveKit ──────────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_EXTERNAL_URL=wss://livekit.your-domain.example
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Server public IP for WebRTC ICE candidates (sonst gehen 10-15 % der
# Clients hinter symmetrischem NAT nicht durch).
LK_NAT_1_TO_1_IPS=0.0.0.0

# ─── Web Build Args (zum Build-Zeitpunkt ins JS-Bundle gebrannt) ──
VITE_API_BASE=https://api.your-domain.example
VITE_LIVEKIT_URL=wss://livekit.your-domain.example
VITE_FEATURE_AV_SETTINGS=true
VITE_FEATURE_VOICE_ISOLATION=on
VITE_DEBUG_LOGS=false

# ─── Traefik ──────────────────────────────────────────────
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=le
WEB_HOST=your-domain.example
API_HOST=api.your-domain.example
LIVEKIT_HOST=livekit.your-domain.example
TURN_HOST=turn.your-domain.example

# ─── Tenancy bootstrap defaults (DB rows take precedence) ─
DEFAULT_TENANT_SLUG=default
TEMPLATE_TENANT_SLUG=default
# OSS_USER_LIMIT=25                  # OSS only; bypassed in Enterprise
# FREE_SEATS_DEFAULT=3               # bootstrap default; internal-tenant DB row overrides
# PUBLIC_REGISTRATION_ENABLED=true   # bootstrap default; internal-tenant DB row overrides

# ─── Public base for invite/guest/verify links ────────────
PUBLIC_BASE_URL=https://your-domain.example

# ─── Admin tools (/tools, Basic Auth) ─────────────────────
# Wenn leer: /tools ist deaktiviert (404).
TOOLS_USER=
TOOLS_PASSWORD=

# ─── Initial seed (nur bei leerer DB) ─────────────────────
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=__CHANGE_ME__
SEED_ADMIN_NAME=Root Admin

# ═══════════════════════════════════════════════════════════
# Brand metadata
# Consumed by the (optional) tenancy submodule mail templates +
# HTML title fallback. Safe to leave at defaults — the brand
# frontend submodule supplies its own i18n strings.
# ═══════════════════════════════════════════════════════════
BRAND_NAME=Workspace
BRAND_DESCRIPTION_DE="Virtuelles Büro für verteilte Teams"
BRAND_DESCRIPTION_EN="Virtual office for distributed teams"
SUPPORT_EMAIL=support@your-domain.example

# ═══════════════════════════════════════════════════════════
# Stripe billing (Enterprise submodule)
# Required only when packages/tenancy-enterprise is initialised
# and you want active billing routes (`/billing/*`).
# Webhook endpoint to configure in Stripe dashboard:
#   URL    : https://api.your-domain.example/billing/webhook
#   Events : customer.subscription.*, invoice.payment_failed,
#            invoice.paid, invoice.payment_action_required,
#            checkout.session.completed, customer.created,
#            customer.deleted, charge.refunded,
#            charge.dispute.created,
#            customer.subscription.trial_will_end,
#            customer.subscription.paused,
#            customer.subscription.resumed
# ═══════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# BILLING_PUBLIC_URL=https://your-domain.example
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ═══════════════════════════════════════════════════════════
# Resend mail (Tenancy submodule)
# Domain must be verified in Resend. When either field is
# missing, the provider falls back to a console stub: invite /
# verify tokens are surfaced via the admin UI / logs instead.
# Sensitive tokens (password reset) never go through this
# module by design.
# ═══════════════════════════════════════════════════════════
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@your-domain.example

# ═══════════════════════════════════════════════════════════
# Desktop auto-updater (optional — only if you ship a signed
# Tauri desktop bundle alongside the web client)
#
# The server route /desktop/update/{target}/{arch}/{version}
# reverse-proxies your private desktop release repo's GitHub
# Releases API and returns the Tauri-updater manifest. Without
# this token the route answers HTTP 503 ("Update service not
# configured"), which is what you'll see in the desktop app's
# console log when the updater fails. PAT scope: Contents:Read
# + Metadata:Read on the desktop release repo (e.g. fine-grained
# token bound to lass-machen/meetropolis-desktop).
# ═══════════════════════════════════════════════════════════
# GITHUB_DESKTOP_PAT=ghp_...

# ─── Observability (optional) ─────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# VITE_SENTRY_DSN=https://...@sentry.io/...
