# =============================================================================
# Meetropolis Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env files with real credentials!
#
# Compose stack in this repo:
#   compose.yaml      Self-host stack — Postgres + Server + Web +
#                     LiveKit. No Traefik (self-hosters bring their
#                     own reverse proxy). Default for `docker
#                     compose up -d`. For local hot-reload, create
#                     a personal `compose.override.yaml` next to it
#                     (gitignored, auto-merged by Docker Compose).
#
# JWT_SECRET and API_TOKEN_PEPPER are required; the stack refuses
# to start until they are set.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# Node environment: development | production | test
# Local-only default. The Docker stack in compose.yaml hard-codes
# NODE_ENV=production for the server and web services, so this value only
# takes effect for a non-Docker `npm run dev` workflow.
NODE_ENV=development

# Server port (Colyseus + Express)
PORT=2567

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Security (REQUIRED - Generate secure values for production!)
# -----------------------------------------------------------------------------

# JWT secret for session tokens (min 32 chars, use: openssl rand -hex 32).
# Also gates the Colyseus `world` room join (see
# apps/server/src/rooms/lifecycle/onAuth.ts): every non-NPC join is
# rejected unless it presents a JWT signed with this secret, so an
# unset/rotated secret invalidates active realtime sessions, not just REST
# auth.
# Intentionally left EMPTY: the compose stack refuses to start until you set
# a value (see the ${JWT_SECRET:?} guard in compose.yaml). Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Pepper for API token hashing (min 16 chars, use: openssl rand -hex 16).
# Also peppers password-reset tokens (PasswordReset.token stores
# sha256(API_TOKEN_PEPPER + token), never the token itself), so rotating this
# value invalidates every API token AND every pending password-reset link.
# Intentionally left EMPTY: the compose stack refuses to start until you set
# a value (see the ${API_TOKEN_PEPPER:?} guard in compose.yaml). Generate with:
#   openssl rand -hex 16
API_TOKEN_PEPPER=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Development: postgresql://postgres:postgres@localhost:5432/meetropolis
# Docker: postgresql://postgres:postgres@db:5432/meetropolis
DATABASE_URL=postgresql://postgres:postgres@db:5432/meetropolis?schema=public

# PostgreSQL credentials (consumed by the db service in compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meetropolis

# Host port for the bundled Postgres. Override if 5432 is already in use,
# e.g. POSTGRES_PORT=5433.
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# LiveKit (Audio/Video)
# -----------------------------------------------------------------------------

# Internal LiveKit URL (server-side, within Docker network)
LIVEKIT_URL=ws://livekit:7880

# External LiveKit URL (client-side, public-facing)
# Development: ws://localhost:7880
# Production: wss://livekit.yourdomain.com
LIVEKIT_EXTERNAL_URL=ws://localhost:7880

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Audio-zone privacy (H4): tunables for the server-side island-membership
# enforcement in apps/server/src/rooms/audioZones/. All optional, shown
# with their defaults. AUDIO_ZONE_RECONCILE_INTERVAL_MS/LIVEKIT_URL
# together gate the RoomServiceClient-based drift-correction reconciler;
# without LIVEKIT_URL/API_KEY/API_SECRET it stays disabled and enforcement
# relies solely on the client-applied LiveKit publisher permissions.
# AUDIO_ZONE_HYSTERESIS_SAMPLES=3
# AUDIO_ZONE_HYSTERESIS_MS=350
# AUDIO_ZONE_RECONCILE_INTERVAL_MS=4000
# AUDIO_ZONE_PUSH_BATCH_MS=100
# How often a player parked mid-exit (stopped moving right after leaving
# a zone) is re-checked against AUDIO_ZONE_HYSTERESIS_MS without waiting
# for another movement sample. Keep well below AUDIO_ZONE_HYSTERESIS_MS.
# AUDIO_ZONE_HYSTERESIS_SWEEP_MS=200

# LiveKit NAT traversal (production only)
# LK_NAT_1_TO_1_IPS=your-server-public-ip
# LK_RTC_USE_EXTERNAL_IP=true
# LK_RTC_TCP_PORT=7881
# LK_RTC_UDP_PORT=7882

# Host LAN IP for LiveKit ICE (Docker Desktop on macOS / Windows). Required
# when joining from a different device on the same network. Defaults to
# 127.0.0.1 which only works for connections from the Docker host itself.
# HOST_IP=192.168.1.42

# Hostname the web container advertises to the browser (Vite HMR host).
# Defaults to "localhost". Set to your LAN IP when accessing the dev server
# from another device.
# DEV_HOST=localhost

# -----------------------------------------------------------------------------
# Optional closed-source modules (paths)
# -----------------------------------------------------------------------------
# The OSS build supports plugging in private modules for marketing/branding,
# multi-tenancy/billing and the desktop client. Point these env vars at
# package directories, or place sibling clones next to this repo under
# ../meetropolis-{brand,enterprise,desktop} and the loader will pick them
# up automatically. Leave unset for a pure OSS build — nothing here is
# required.
# MEETROPOLIS_BRAND_PATH=../meetropolis-brand
# MEETROPOLIS_ENTERPRISE_PATH=../meetropolis-enterprise
# MEETROPOLIS_DESKTOP_PATH=../meetropolis-desktop

# -----------------------------------------------------------------------------
# Brand / Marketing (only consumed by the optional brand module)
# -----------------------------------------------------------------------------
# Irrelevant for pure OSS builds.

# Application title displayed in <title> and HTML head. Falls back to a
# generic "Virtual Office (Self-Hosted)" string when unset.
# VITE_APP_TITLE="Virtual Office (Self-Hosted)"

# Marketing tracking pixel ID. Only consumed by the optional brand module.
# Self-hosters must NOT reuse a third-party production pixel; either
# provide your own ID or leave unset to disable tracking.
# VITE_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------

# API base URL (public-facing)
# Development: http://localhost:2567
# Production: https://api.yourdomain.com
VITE_API_BASE=http://localhost:2567

# LiveKit URL for client
# Development: ws://localhost:7880
# Production: wss://livekit.yourdomain.com
VITE_LIVEKIT_URL=ws://localhost:7880

# Feature flags
VITE_FEATURE_AV_SETTINGS=true
VITE_FEATURE_VOICE_ISOLATION=on
# VITE_FEATURE_VOICE_ONLY=true

# -----------------------------------------------------------------------------
# Client Connection Timeouts (milliseconds)
# -----------------------------------------------------------------------------
# Guard against cold-start hangs where slow server responses would otherwise
# leave client promises pending indefinitely. Values are milliseconds.

# LiveKit token fetch timeout (POST /livekit/token)
# VITE_LIVEKIT_TOKEN_TIMEOUT_MS=10000

# LiveKit room connect timeout (room.connect)
# VITE_LIVEKIT_CONNECT_TIMEOUT_MS=10000

# LiveKit URL discovery timeout (GET /livekit/url, Desktop only)
# VITE_LIVEKIT_URL_TIMEOUT_MS=5000

# Colyseus joinOrCreate timeout (WebSocket join handshake)
# VITE_COLYSEUS_JOIN_TIMEOUT_MS=15000

# Colyseus initial state sync timeout (after join, before first state)
# VITE_COLYSEUS_STATE_TIMEOUT_MS=5000

# Microphone publish timeout (track creation + publishTrack)
# VITE_MIC_PUBLISH_TIMEOUT_MS=10000

# Debug options (development only!)
VITE_DEBUG_LOGS=true
VITE_DEBUG_AUTOLOGIN=false
# VITE_DEBUG_AUTOLOGIN_EMAIL=admin@meetropolis.local
# VITE_DEBUG_AUTOLOGIN_PASSWORD=admin123

# HMR (Hot Module Replacement) for development
VITE_HMR_HOST=localhost
VITE_HMR_PROTOCOL=ws

# -----------------------------------------------------------------------------
# CORS & Proxy
# -----------------------------------------------------------------------------

# Allowed origins (comma-separated)
# Development: http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.com,https://*.yourdomain.com,tauri://localhost,http://tauri.localhost
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Trust proxy headers. Set this to the NUMBER of reverse-proxy hops in front of
# the server (e.g. 1 for a single Traefik). Express then derives the client IP
# (req.ip, used for request logging and rate limiting) from the proxy-verified
# end of X-Forwarded-For, which clients cannot spoof. `true` trusts the whole
# forwarded chain and lets a client forge its IP to bypass IP-based rate
# limiting; `false` disables proxy trust for direct connections.
TRUST_PROXY=1

# Secure cookies (set true in production with HTTPS)
COOKIE_SECURE=false

# Public-facing base URL fuer Invite-/Guest-/Verify-Links, die der OSS-Server
# in API-Responses ausliefert (zum manuellen Weitergeben durch den Admin).
# Wenn unset, sind die Links relativ. Self-Hoster sollten ihre oeffentliche
# Web-URL setzen.
# PUBLIC_BASE_URL=https://app.example.com

# Public registration toggle (OSS fallback when no enterprise settings are
# stored). When unset, registration is enabled. Set to "false" or "0" to
# disable for an OSS-only deployment.
# PUBLIC_REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Rate limiting (public auth / sign-up endpoints)
# -----------------------------------------------------------------------------
# The unauthenticated auth and sign-up endpoints are rate limited per client IP
# (requires a correct TRUST_PROXY above). Limits are on by default; the values
# below are the built-in defaults and only need to be set to override them.
# _WINDOW_MS is the rolling window in milliseconds, _MAX the allowed requests
# per IP per window. Responses carry standard RateLimit-* headers and a 429 with
# Retry-After once exceeded.
#
# Global kill-switch (debugging / load tests only — do not disable in prod):
# RATE_LIMIT_ENABLED=true
#
# POST /auth/login — only failed logins count, so a successful login is never
# throttled (default: 10 failed attempts / 15 min):
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=10
#
# POST /auth/register — invite-code redemption (default: 10 / 60 min):
# RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# RATE_LIMIT_REGISTER_MAX=10
#
# POST /auth/forgot + /auth/reset — password reset, per IP (default: 10 / 15 min):
# RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=900000
# RATE_LIMIT_PASSWORD_RESET_MAX=10
#
# POST /auth/forgot — second budget, keyed by the REQUESTED E-MAIL ADDRESS
# instead of the client IP, on top of the per-IP limit above. /auth/forgot mails
# a real reset link, so this is what stops a distributed caller from flooding one
# known mailbox (or repeatedly invalidating the link its owner is trying to use)
# from many IPs. A real user needs one mail, plus a retry (default: 3 / 60 min):
# RATE_LIMIT_FORGOT_PASSWORD_EMAIL_WINDOW_MS=3600000
# RATE_LIMIT_FORGOT_PASSWORD_EMAIL_MAX=3
#
# POST /auth/verify + /auth/verify/request — e-mail verification (default: 10 / 15 min):
# RATE_LIMIT_EMAIL_VERIFICATION_WINDOW_MS=900000
# RATE_LIMIT_EMAIL_VERIFICATION_MAX=10
#
# POST /auth/guest — guest magic-link redemption (default: 20 / 15 min):
# RATE_LIMIT_GUEST_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_GUEST_LOGIN_MAX=20
#
# POST /public/tenants — enterprise tenant sign-up, strictest (default: 5 / 60 min):
# RATE_LIMIT_TENANT_SIGNUP_WINDOW_MS=3600000
# RATE_LIMIT_TENANT_SIGNUP_MAX=5
#
# POST /me/avatar/compose — character-editor compositing (default: 20 / 60s):
# RATE_LIMIT_AVATAR_COMPOSE_WINDOW_MS=60000
# RATE_LIMIT_AVATAR_COMPOSE_MAX=20
#
# POST /avatars/resolve — avatar-manifest lookup; read-only and client-batched,
# so this is a backstop, set well above avatar_compose (default: 60 / 60s):
# RATE_LIMIT_AVATAR_RESOLVE_WINDOW_MS=60000
# RATE_LIMIT_AVATAR_RESOLVE_MAX=60

# Template tenant slug — every new tenant receives a copy of THIS tenant's
# default map on sign-up (Enterprise only). Point it at a dedicated blueprint
# tenant, never at a workspace people actually use: a real workspace collects
# drafts and scratch maps, and each new customer would inherit them. The seed
# bootstraps the tenant named here (apps/server/prisma/seed.ts). Defaults to
# `template` in code when unset.
# TEMPLATE_TENANT_SLUG=template

# -----------------------------------------------------------------------------
# Character editor (Phase 2)
# -----------------------------------------------------------------------------
# In-app avatar editor: the user composes an avatar from slots and the server
# composites the 128x256 sheet once and stores it as a custom avatar. Gated OFF
# by default — this turns on BOTH the editor UI and the compose/resolve
# endpoints (when off they return 404).
# AVATAR_EDITOR_ENABLED=false
#
# Path to the v5 sprite catalog (packages/shared/sprite/catalog.json). Optional
# override; by default the server finds the copy shipped next to its build (or
# the workspace file in dev).
# SPRITE_CATALOG_PATH=/abs/path/to/catalog.json

# -----------------------------------------------------------------------------
# Stripe Billing (only consumed by the optional enterprise module)
# -----------------------------------------------------------------------------
# Irrelevant for pure OSS builds. The OSS server contains no Stripe code.

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL for billing redirects
# BILLING_PUBLIC_URL=https://yourdomain.com

# Price IDs for different plans (optional, can use priceId directly)
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# -----------------------------------------------------------------------------
# Email delivery (OSS-SMTP via nodemailer)
# -----------------------------------------------------------------------------
# The OSS server can send transactional email (invites, guest magic links,
# verify links, welcome emails, password-reset links) over plain SMTP via
# nodemailer.
#
# Password reset is self-service: POST /auth/forgot mails a single-use link
# that expires after 30 minutes (the token is stored hashed, see
# API_TOKEN_PEPPER). Without a configured provider no reset mail can be
# delivered and the admin path (POST /admin/users/:id/reset-token, token handed
# over out of band) is the only way to reset a password — which leaves a tenant
# owner who forgot theirs with nobody above them to ask. Configure a provider.
#
# Provider precedence at boot (first match wins):
#   1. EE-Resend, when the optional `@meetropolis/tenancy` module is loaded
#      AND `RESEND_API_KEY` + `RESEND_FROM` are set.
#   2. OSS-SMTP, when `SMTP_HOST` + `SMTP_FROM` are set.
#   3. OSS-Console fallback: logs subject + recipient domain only, returns
#      `false` from send() so verify-requests keep surfacing tokens via the
#      API response. A WARN log fires once at boot.
#
# See README.md "Production Mail Setup" for DKIM/SPF/DMARC guidance and
# recommended providers (SES, Brevo/Mailgun, Postmark, Resend-SMTP).
#
# SMTP host (enables OSS-SMTP when set together with SMTP_FROM).
# Examples: smtp.brevo.com, email-smtp.eu-central-1.amazonaws.com,
# smtp.postmarkapp.com, smtp.resend.com, sandbox.smtp.mailtrap.io
# SMTP_HOST=

# SMTP port. Typical values: 587 (STARTTLS), 465 (TLS), 25 (plain).
# SMTP_PORT=587

# Encryption mode: true (direct TLS, usually port 465), false (STARTTLS),
# or "auto" (derive from SMTP_PORT — 465 → true, else false).
# SMTP_SECURE=auto

# Auth credentials. Some providers (SES, Postmark) require these for any
# port; others (e.g. a local Postfix relay) allow unauthenticated submit.
# SMTP_USER=
# SMTP_PASS=

# Sender address. Must be DKIM/SPF-aligned with your sending domain.
# Display-name form is supported: "Meetropolis <noreply@example.com>"
# SMTP_FROM=

# Optional reply-to header for replies (helpful for transactional mails).
# SMTP_REPLY_TO=support@example.com

# Connection pool. Default OFF — invites/welcome/verify are low-frequency
# transactional emails, the per-mail TCP cost is negligible.
# SMTP_POOL=false

# TLS validation. Default true (recommended). NEVER set to false in
# production unless you are connecting to an internal relay with a known
# self-signed cert. Mailpit/Mailtrap-sandbox developers may set this to
# false locally.
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Verify SMTP connectivity at boot. Default OFF. When ON, runs a fire-and-
# forget `verify()` (10 s hard cap) and logs `email.smtp.verify_failed` on
# error — server boot is never blocked.
# SMTP_VERIFY_ON_BOOT=false

# -----------------------------------------------------------------------------
# Mail branding (OSS-stack only — independent of the EE-tenancy BRAND_* vars)
# -----------------------------------------------------------------------------
# These ENVs are read by the OSS mail templates. They are independent of
# the EE-tenancy BRAND_NAME/BRAND_DESCRIPTION_* knobs and intentionally
# minimal: brand polish is an EE feature.
#
# Display name in subjects, headings and footer. Default: "Meetropolis".
# MAIL_BRAND_NAME=Meetropolis
#
# Default locale when neither the caller nor the recipient User.locale row
# supplies one. Accepts "de" or "en". Default: "de".
# MAIL_DEFAULT_LOCALE=de
#
# Optional support address rendered into the welcome footer.
# MAIL_SUPPORT_EMAIL=support@example.com

# -----------------------------------------------------------------------------
# EE-Resend (only consumed by the optional enterprise module)
# -----------------------------------------------------------------------------
# If the optional `@meetropolis/tenancy` module is loaded AND both
# RESEND_API_KEY and RESEND_FROM are set, the EE-Resend provider takes
# precedence over the OSS-SMTP stack above.
#
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM=noreply@yourdomain.com
#
# Additional EE-tenancy brand knobs (read only by the EE templates):
# BRAND_NAME="Workspace"
# BRAND_DESCRIPTION_DE="Beschreibung deiner Plattform"
# BRAND_DESCRIPTION_EN="Description of your platform"
# SUPPORT_EMAIL=support@yourdomain.com

# -----------------------------------------------------------------------------
# Admin Tools (served at /tools, disabled if unset)
# -----------------------------------------------------------------------------

# HTTP Basic Auth credentials for the /tools route
# TOOLS_USER=admin
# TOOLS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# NPC Service
# -----------------------------------------------------------------------------

# Internal URL of the NPC service (for server-to-service communication)
NPC_SERVICE_URL=http://npc-service:3100

# Shared secret for NPC service authentication. Presented by npc-service as
# `serviceToken` on every Colyseus `world` join for an `npc-*` identity (see
# apps/server/src/rooms/lifecycle/onAuth.ts). REQUIRED in production: the
# server refuses NPC joins in production if this is unset or left at the
# `dev-npc-secret` default. Generate with: openssl rand -hex 32
NPC_SERVICE_SECRET=dev-npc-secret

# Directory for NPC media file storage (shared volume between server and NPC service)
NPC_MEDIA_DIR=/data/npc-media

# Server URL as seen from NPC service (internal Docker network)
# NPC_SERVER_URL=http://server:2567

# -----------------------------------------------------------------------------
# Reverse proxy / public domains
# -----------------------------------------------------------------------------
# The bundled compose.yaml ships no reverse proxy — self-hosters bring their
# own (Traefik, Caddy, nginx, …). Domain routing, TLS and any proxy-specific
# environment belong in a personal `compose.override.yaml` next to compose.yaml
# (gitignored, auto-merged by Docker Compose), not in this file.

# -----------------------------------------------------------------------------
# Seed Data (Development only)
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@meetropolis.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Root Admin
