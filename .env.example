# =============================================================================
# Meetropolis Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env files with real credentials!
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Server port (Colyseus + Express)
PORT=2567

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Security (REQUIRED - Generate secure values for production!)
# -----------------------------------------------------------------------------

# JWT secret for session tokens (min 32 chars, use: openssl rand -hex 32)
JWT_SECRET=please-change-me-to-a-secure-random-string

# Pepper for API token hashing (min 16 chars, use: openssl rand -hex 16)
API_TOKEN_PEPPER=dev-pepper-change-me

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Development: postgresql://postgres:postgres@localhost:5432/meetropolis
# Docker: postgresql://postgres:postgres@db:5432/meetropolis
DATABASE_URL=postgresql://postgres:postgres@db:5432/meetropolis?schema=public

# PostgreSQL credentials (consumed by the db service in compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meetropolis

# Host port for the bundled Postgres. Override if 5432 is already in use,
# e.g. POSTGRES_PORT=5433.
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# LiveKit (Audio/Video)
# -----------------------------------------------------------------------------

# Internal LiveKit URL (server-side, within Docker network)
LIVEKIT_URL=ws://livekit:7880

# External LiveKit URL (client-side, public-facing)
# Development: ws://localhost:7880
# Production: wss://livekit.yourdomain.com
LIVEKIT_EXTERNAL_URL=ws://localhost:7880

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit NAT traversal (production only)
# LK_NAT_1_TO_1_IPS=your-server-public-ip
# LK_RTC_USE_EXTERNAL_IP=true
# LK_RTC_TCP_PORT=7881
# LK_RTC_UDP_PORT=7882

# Host LAN IP for LiveKit ICE (Docker Desktop on macOS / Windows). Required
# when joining from a different device on the same network. Defaults to
# 127.0.0.1 which only works for connections from the Docker host itself.
# HOST_IP=192.168.1.42

# Hostname the web container advertises to the browser (Vite HMR host).
# Defaults to "localhost". Set to your LAN IP when accessing the dev server
# from another device.
# DEV_HOST=localhost

# -----------------------------------------------------------------------------
# Optional closed-source modules (paths)
# -----------------------------------------------------------------------------
# The OSS build supports plugging in private modules for marketing/branding,
# multi-tenancy/billing and the desktop client. Point these env vars at
# package directories, or place sibling clones next to this repo under
# ../meetropolis-{brand,enterprise,desktop} and the loader will pick them
# up automatically. Leave unset for a pure OSS build — nothing here is
# required.
# MEETROPOLIS_BRAND_PATH=../meetropolis-brand
# MEETROPOLIS_ENTERPRISE_PATH=../meetropolis-enterprise
# MEETROPOLIS_DESKTOP_PATH=../meetropolis-desktop

# -----------------------------------------------------------------------------
# Brand / Marketing (only consumed by the optional brand module)
# -----------------------------------------------------------------------------
# Irrelevant for pure OSS builds.

# Application title displayed in <title> and HTML head. Falls back to a
# generic "Virtual Office (Self-Hosted)" string when unset.
# VITE_APP_TITLE="Virtual Office (Self-Hosted)"

# Marketing tracking pixel ID. Only consumed by the optional brand module.
# Self-hosters must NOT reuse a third-party production pixel; either
# provide your own ID or leave unset to disable tracking.
# VITE_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------

# API base URL (public-facing)
# Development: http://localhost:2567
# Production: https://api.yourdomain.com
VITE_API_BASE=http://localhost:2567

# LiveKit URL for client
# Development: ws://localhost:7880
# Production: wss://livekit.yourdomain.com
VITE_LIVEKIT_URL=ws://localhost:7880

# Feature flags
VITE_FEATURE_AV_SETTINGS=true
VITE_FEATURE_VOICE_ISOLATION=client
# VITE_FEATURE_VOICE_ONLY=true

# -----------------------------------------------------------------------------
# Client Connection Timeouts (milliseconds)
# -----------------------------------------------------------------------------
# Guard against cold-start hangs where slow server responses would otherwise
# leave client promises pending indefinitely. Values are milliseconds.

# LiveKit token fetch timeout (POST /livekit/token)
# VITE_LIVEKIT_TOKEN_TIMEOUT_MS=10000

# LiveKit room connect timeout (room.connect)
# VITE_LIVEKIT_CONNECT_TIMEOUT_MS=10000

# LiveKit URL discovery timeout (GET /livekit/url, Desktop only)
# VITE_LIVEKIT_URL_TIMEOUT_MS=5000

# Colyseus joinOrCreate timeout (WebSocket join handshake)
# VITE_COLYSEUS_JOIN_TIMEOUT_MS=15000

# Colyseus initial state sync timeout (after join, before first state)
# VITE_COLYSEUS_STATE_TIMEOUT_MS=5000

# Microphone publish timeout (track creation + publishTrack)
# VITE_MIC_PUBLISH_TIMEOUT_MS=10000

# Debug options (development only!)
VITE_DEBUG_LOGS=true
VITE_DEBUG_AUTOLOGIN=false
# VITE_DEBUG_AUTOLOGIN_EMAIL=admin@meetropolis.local
# VITE_DEBUG_AUTOLOGIN_PASSWORD=admin123

# HMR (Hot Module Replacement) for development
VITE_HMR_HOST=localhost
VITE_HMR_PROTOCOL=ws

# -----------------------------------------------------------------------------
# CORS & Proxy
# -----------------------------------------------------------------------------

# Allowed origins (comma-separated)
# Development: http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.com,https://*.yourdomain.com,tauri://localhost
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Trust proxy headers (set true when behind reverse proxy)
TRUST_PROXY=true

# Secure cookies (set true in production with HTTPS)
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Tenancy
# -----------------------------------------------------------------------------

# Default tenant slug for single-tenant mode
DEFAULT_TENANT_SLUG=default

# Default free seats for new tenants
FREE_SEATS_DEFAULT=3

# OSS concurrent-user limit (default: 25). Enterprise edition bypasses this
# entirely. Self-hosters may raise this if they have purchased a commercial
# license.
# OSS_USER_LIMIT=25

# Public-facing base URL fuer Invite-/Guest-/Verify-Links, die der OSS-Server
# in API-Responses ausliefert (zum manuellen Weitergeben durch den Admin).
# Wenn unset, sind die Links relativ. Self-Hoster sollten ihre oeffentliche
# Web-URL setzen.
# PUBLIC_BASE_URL=https://app.example.com

# Public registration toggle (OSS fallback when no enterprise settings are
# stored). When unset, registration is enabled. Set to "false" or "0" to
# disable for an OSS-only deployment.
# PUBLIC_REGISTRATION_ENABLED=true

# Template tenant slug — new tenants receive copies of this tenant's maps (Enterprise only)
# TEMPLATE_TENANT_SLUG=default

# -----------------------------------------------------------------------------
# Stripe Billing (only consumed by the optional enterprise module)
# -----------------------------------------------------------------------------
# Irrelevant for pure OSS builds. The OSS server contains no Stripe code.

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL for billing redirects
# BILLING_PUBLIC_URL=https://yourdomain.com

# Price IDs for different plans (optional, can use priceId directly)
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# -----------------------------------------------------------------------------
# Email delivery (only consumed by the optional enterprise module)
# -----------------------------------------------------------------------------
# The OSS server intentionally contains NO email code. Invite, guest and
# verify tokens are shown in the admin UI and passed on manually. Sensitive
# tokens (password reset) are never sent by email — the admin generates them
# via the admin UI.
#
# To enable transactional email, install the optional enterprise module
# (closed-source, commercial). The following variables are read by that
# module only:
#
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM=noreply@yourdomain.com
# BRAND_NAME="Workspace"
# BRAND_DESCRIPTION_DE="Beschreibung deiner Plattform"
# BRAND_DESCRIPTION_EN="Description of your platform"
# SUPPORT_EMAIL=support@yourdomain.com
#
# With both RESEND_API_KEY and RESEND_FROM set, delivery goes via Resend.
# Otherwise a console-log provider is used for dev.

# -----------------------------------------------------------------------------
# Admin Tools (served at /tools, disabled if unset)
# -----------------------------------------------------------------------------

# HTTP Basic Auth credentials for the /tools route
# TOOLS_USER=admin
# TOOLS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# NPC Service
# -----------------------------------------------------------------------------

# Internal URL of the NPC service (for server-to-service communication)
NPC_SERVICE_URL=http://npc-service:3100

# Shared secret for NPC service authentication
NPC_SERVICE_SECRET=dev-npc-secret

# Directory for NPC media file storage (shared volume between server and NPC service)
NPC_MEDIA_DIR=/data/npc-media

# Server URL as seen from NPC service (internal Docker network)
# NPC_SERVER_URL=http://server:2567

# -----------------------------------------------------------------------------
# Error Tracking (Production only)
# -----------------------------------------------------------------------------

# Sentry DSN for error reporting
# SENTRY_DSN=https://...@sentry.io/...
# VITE_SENTRY_DSN=https://...@sentry.io/...

# -----------------------------------------------------------------------------
# Docker/Traefik (Production only)
# -----------------------------------------------------------------------------

# Domain configuration
# WEB_HOST=yourdomain.com
# API_HOST=api.yourdomain.com
# LIVEKIT_HOST=livekit.yourdomain.com
# TURN_HOST=turn.yourdomain.com

# Traefik network name
# TRAEFIK_NETWORK=traefik
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERT_RESOLVER=le

# -----------------------------------------------------------------------------
# Seed Data (Development only)
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@meetropolis.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Root Admin
