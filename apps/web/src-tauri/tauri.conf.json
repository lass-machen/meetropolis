{
  "build": {
    "beforeDevCommand": "echo 'Skipping local dev server'",
    "beforeBuildCommand": "echo 'Skipping frontend build - using local-client'",
    "devPath": "../src-tauri/local-client",
    "distDir": "../src-tauri/local-client",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Meetropolis",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://**", "https://**"]
      },
      "fs": {
        "all": true,
        "scope": ["$APPCONFIG/*", "$APPCACHE/*", "$APPDATA/*"]
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.meetropolis.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Meetropolis",
        "width": 1280,
        "height": 800,
        "center": true,
        "fileDropEnabled": false
      }
    ],
    "macOSPrivateApi": true
  }
}
