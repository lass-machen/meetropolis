{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meetropolis",
  "version": "0.1.0",
  "identifier": "com.meetropolis.desktop",
  "build": {
    "beforeDevCommand": "echo 'Skipping local dev server'",
    "beforeBuildCommand": "echo 'Skipping frontend build - using local-client'",
    "devUrl": "file:///Users/ricoroder/Cursor/meetropolis/apps/web/src-tauri/local-client/index.html",
    "frontendDist": "./local-client"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Meetropolis",
        "width": 1280,
        "height": 800,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  }
}
