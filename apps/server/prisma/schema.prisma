generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  presences Presence[]
}

model Map {
  id        String   @id @default(cuid())
  name      String   @unique
  meta      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
  zones     Zone[]
}

model Room {
  id        String   @id @default(cuid())
  name      String
  map       Map      @relation(fields: [mapId], references: [id])
  mapId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zones     Zone[]
  presences Presence[]
}

model Zone {
  id         String   @id @default(cuid())
  name       String
  capacity   Int?
  polygon    Json
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Presence {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  x          Int
  y          Int
  direction  String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

