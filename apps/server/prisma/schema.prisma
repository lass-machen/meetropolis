generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma seed configuration (uses TS seed file)
// This is read by `prisma db seed` via package.json in the server workspace.

enum Role {
  owner
  admin
  member
  guest
}


enum PackPricingModel {
  free
  one_time
  subscription
}

model Tenant {
  id                    String       @id @default(cuid())
  slug                  String       @unique
  name                  String
  concurrentLimit       Int          @default(50)
  freeSeats             Int          @default(3)
  bypassLimits          Boolean      @default(false)
  isInternal            Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Default map for this tenant
  defaultMapName    String?   @default("office")

  publicRegistrationEnabled Boolean @default(true)

  // Enterprise billing fields
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  status                String?
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  trialConvertedAt      DateTime?
  paymentFailedAt       DateTime?
  gracePeriodEndsAt     DateTime?
  dunningStep           Int?       @default(0)
  lastDunningEmailAt    DateTime?
  pausedAt              DateTime?
  pauseEndsAt           DateTime?
  pauseReason           String?

  memberships           Membership[]
  maps                  Map[]
  rooms                 Room[]
  zones                 Zone[]
  presences             Presence[]
  invites               Invite[]
  npcs                  Npc[]
  billingAuditLogs      BillingAuditLog[]
  tenantAssetPacks      TenantAssetPack[]
  tenantAvatarPacks     TenantAvatarPack[]
}

model Membership {
  id         String      @id @default(cuid())
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  tenantId   String
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  role       Role        @default(member)
  expiresAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  guestToken GuestToken?

  @@unique([tenantId, userId])
}

model GuestToken {
  id           String     @id @default(cuid())
  token        String     @unique
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  membershipId String     @unique
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String?
  imageUrl            String?
  avatarId            String?
  passwordHash        String?
  emailVerifiedAt     DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  onboardingCompleted Boolean             @default(false)
  locale              String              @default("de")
  presences           Presence[]
  passwordResets      PasswordReset[]
  emailVerifications  EmailVerification[]
  apiTokens           ApiToken[]
  memberships         Membership[]
  sessions            Session[]
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  createdAt DateTime @default(now())
  createdBy String?
  usedAt    DateTime?
  usedById  String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  role      Role     @default(member)
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  email     String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  name       String?
  hash       String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model Session {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  tokenHash    String    @unique
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Map {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String
  meta      Json
  // v2 Map Geometry & Settings
  width      Int?
  height     Int?
  tileWidth  Int?
  tileHeight Int?
  chunkSize  Int?     @default(32)
  version    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
  zones     Zone[]
  // v2 relations
  tilesets  MapTileset[]
  layers    MapLayer[]
  objects   MapObject[]

  @@unique([tenantId, name])
}

model Room {
  id        String   @id @default(cuid())
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  map       Map      @relation(fields: [mapId], references: [id])
  mapId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zones     Zone[]
  presences Presence[]

  @@unique([mapId, name])
}

model Zone {
  id            String   @id @default(cuid())
  name          String
  capacity      Int?
  polygon       Json
  type          String?   // 'default' | 'portal'
  portalTarget  String?   // target map name (for portal zones)
  portalSpawnX  Int?      // optional target X coordinate
  portalSpawnY  Int?      // optional target Y coordinate
  room          Room     @relation(fields: [roomId], references: [id])
  roomId        String
  map           Map      @relation(fields: [mapId], references: [id])
  mapId         String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Presence {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  x          Int
  y          Int
  direction  String
  mapName    String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([userId, roomId])
}

model AssetPack {
  id           Int                @id @default(autoincrement())
  uuid         String             @unique
  name         String
  description  String
  author       String
  version      String
  terrain      Json
  structures   Json
  objects      Json
  autotiles    Json               @default("[]")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  catalog      AssetPackCatalog?
  tenantAssetPacks TenantAssetPack[]
}

model AvatarPack {
  id           Int                 @id @default(autoincrement())
  uuid         String              @unique
  name         String
  description  String
  author       String
  version      String
  type         String              @default("full")
  avatars      Json
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  catalog      AvatarPackCatalog?
  tenantAvatarPacks TenantAvatarPack[]
}

/// v2: Deterministische Tileset-Registry pro Map
model MapTileset {
  id         String   @id @default(cuid())
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  slot       Int
  key        String
  imageUrl   String
  tileWidth  Int
  tileHeight Int
  margin     Int?
  spacing    Int?
  hash       String?
  tileCount  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([mapId, slot])
  @@index([mapId])
}

/// v2: Logische Layer pro Map (z. B. ground, walls, collision)
model MapLayer {
  id         String      @id @default(cuid())
  map        Map         @relation(fields: [mapId], references: [id])
  mapId      String
  name       String
  chunkSize  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chunks     MapChunk[]

  @@unique([mapId, name])
  @@index([mapId])
}

/// v2: Chunk-basierte Speicherung von Layer-Daten
model MapChunk {
  id        String   @id @default(cuid())
  layer     MapLayer @relation(fields: [layerId], references: [id])
  layerId   String
  x         Int
  y         Int
  version   Int
  encoding  String   // 'rle' | 'rle-bool' | 'gzip+rle'
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([layerId, x, y])
  @@index([layerId])
}

model MapObject {
  id             Int      @id @default(autoincrement())
  mapId          String
  map            Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  assetPackUuid  String
  itemId         String
  category       String   // 'structure' | 'objects'
  tileX          Int
  tileY          Int
  chunkX         Int      // floor(tileX / chunkSize)
  chunkY         Int      // floor(tileY / chunkSize)
  width          Int
  height         Int
  collide        Boolean  @default(false)
  zIndex         Int      @default(0)
  rotation       Int      @default(0)
  flipX          Boolean  @default(false)
  flipY          Boolean  @default(false)
  scaleFactor    Float    @default(1)
  dataUrl        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([mapId, chunkX, chunkY])
}

enum NpcMediaType {
  audio
  video
  screenshare
}

model Npc {
  id             String         @id @default(cuid())
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  tenantId       String
  identity       String         // unique per tenant, e.g. "npc-greeter"
  name           String         // display name
  avatarId       String         @default("default-characters:businessman1")
  spawnX         Float          @default(200)
  spawnY         Float          @default(200)
  spawnDirection String         @default("down")
  enabled        Boolean        @default(true)
  showBadge      Boolean        @default(false)
  mapName        String?        // optional: which map this NPC should spawn on
  config         Json?          // arbitrary JSON config
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  mediaFiles     NpcMediaFile[]

  @@unique([tenantId, identity])
  @@index([tenantId])
}

model NpcMediaFile {
  id          String       @id @default(cuid())
  npc         Npc          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  npcId       String
  filename    String       // original filename
  storagePath String       // path on disk relative to NPC_MEDIA_DIR
  mimeType    String
  sizeBytes   Int
  duration    Float?       // seconds, null if unknown
  mediaType   NpcMediaType
  createdAt   DateTime     @default(now())

  @@index([npcId])
}


// Enterprise: Asset Pack Marketplace Catalog
model AssetPackCatalog {
  id               String           @id @default(cuid())
  assetPack        AssetPack        @relation(fields: [assetPackId], references: [id], onDelete: Cascade)
  assetPackId      Int              @unique
  pricingModel     PackPricingModel @default(free)
  stripeProductId  String?
  stripePriceId    String?
  priceAmountCents Int              @default(0)
  priceCurrency    String           @default("EUR")
  priceInterval    String?
  published        Boolean          @default(false)
  featured         Boolean          @default(false)
  previewImageUrl  String?
  tags             String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Enterprise: Avatar Pack Marketplace Catalog
model AvatarPackCatalog {
  id               String           @id @default(cuid())
  avatarPack       AvatarPack       @relation(fields: [avatarPackId], references: [id], onDelete: Cascade)
  avatarPackId     Int              @unique
  pricingModel     PackPricingModel @default(free)
  stripeProductId  String?
  stripePriceId    String?
  priceAmountCents Int              @default(0)
  priceCurrency    String           @default("EUR")
  priceInterval    String?
  published        Boolean          @default(false)
  featured         Boolean          @default(false)
  previewImageUrl  String?
  tags             String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Enterprise: Tenant <-> AssetPack ownership
model TenantAssetPack {
  id                     String    @id @default(cuid())
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId               String
  assetPack              AssetPack @relation(fields: [assetPackId], references: [id], onDelete: Cascade)
  assetPackId            Int
  grantSource            String
  purchasedMajorVersion  Int       @default(0)
  stripePaymentId        String?
  expiresAt              DateTime?
  revokedAt              DateTime?
  grantedBy              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([tenantId, assetPackId])
  @@index([tenantId])
  @@index([assetPackId])
}

// Enterprise: Tenant <-> AvatarPack ownership
model TenantAvatarPack {
  id                     String     @id @default(cuid())
  tenant                 Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId               String
  avatarPack             AvatarPack @relation(fields: [avatarPackId], references: [id], onDelete: Cascade)
  avatarPackId           Int
  grantSource            String
  purchasedMajorVersion  Int        @default(0)
  stripePaymentId        String?
  expiresAt              DateTime?
  revokedAt              DateTime?
  grantedBy              String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@unique([tenantId, avatarPackId])
  @@index([tenantId])
  @@index([avatarPackId])
}

// Enterprise: Billing Audit Log
model BillingAuditLog {
  id             String   @id @default(cuid())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  eventType      String
  eventSource    String
  stripeEventId  String?
  previousValues Json?
  newValues      Json?
  triggeredBy    String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
  @@index([stripeEventId])
}

model PricingPlan {
  id              String   @id @default(cuid())
  stripeProductId String?  @unique
  stripePriceId   String?
  name            Json
  description     Json?
  priceAmount     Int?
  priceCurrency   String   @default("EUR")
  priceInterval   String?
  priceLabel      Json?
  unitLabel       Json?
  features        Json     @default("[]")
  ctaLabel        Json
  ctaUrl          String?
  highlighted     Boolean  @default(false)
  badgeLabel      Json?
  customPricing   Boolean  @default(false)
  sortOrder       Int      @default(0)
  visible         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sortOrder])
}
