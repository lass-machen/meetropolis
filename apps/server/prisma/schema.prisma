generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma seed configuration (uses TS seed file)
// This is read by `prisma db seed` via package.json in the server workspace.

enum Role {
  owner
  admin
  member
  guest
}

model Tenant {
  id                    String       @id @default(cuid())
  slug                  String       @unique
  name                  String
  concurrentLimit       Int          @default(50)
  freeSeats             Int          @default(3)
  bypassLimits          Boolean      @default(false)
  isInternal            Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Default map for this tenant
  defaultMapName    String?   @default("office")

  publicRegistrationEnabled Boolean @default(true)

  memberships           Membership[]
  maps                  Map[]
  rooms                 Room[]
  zones                 Zone[]
  presences             Presence[]
  invites               Invite[]
  npcs                  Npc[]
}

model Membership {
  id         String      @id @default(cuid())
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  tenantId   String
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  role       Role        @default(member)
  expiresAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  guestToken GuestToken?

  @@unique([tenantId, userId])
}

model GuestToken {
  id           String     @id @default(cuid())
  token        String     @unique
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  membershipId String     @unique
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String?
  imageUrl            String?
  avatarId            String?
  passwordHash        String?
  emailVerifiedAt     DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  onboardingCompleted Boolean             @default(false)
  locale              String              @default("de")
  presences           Presence[]
  passwordResets      PasswordReset[]
  emailVerifications  EmailVerification[]
  apiTokens           ApiToken[]
  memberships         Membership[]
  sessions            Session[]
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  createdAt DateTime @default(now())
  createdBy String?
  usedAt    DateTime?
  usedById  String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  role      Role     @default(member)
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  email     String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  name       String?
  hash       String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model Session {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  tokenHash    String    @unique
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Map {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String
  meta      Json
  // v2 Map Geometry & Settings
  width      Int?
  height     Int?
  tileWidth  Int?
  tileHeight Int?
  chunkSize  Int?     @default(32)
  version    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
  zones     Zone[]
  // v2 relations
  tilesets  MapTileset[]
  layers    MapLayer[]
  objects   MapObject[]

  @@unique([tenantId, name])
}

model Room {
  id        String   @id @default(cuid())
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  map       Map      @relation(fields: [mapId], references: [id])
  mapId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zones     Zone[]
  presences Presence[]

  @@unique([mapId, name])
}

model Zone {
  id            String   @id @default(cuid())
  name          String
  capacity      Int?
  polygon       Json
  type          String?   // 'default' | 'portal'
  portalTarget  String?   // target map name (for portal zones)
  portalSpawnX  Int?      // optional target X coordinate
  portalSpawnY  Int?      // optional target Y coordinate
  room          Room     @relation(fields: [roomId], references: [id])
  roomId        String
  map           Map      @relation(fields: [mapId], references: [id])
  mapId         String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Presence {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  x          Int
  y          Int
  direction  String
  mapName    String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([userId, roomId])
}

model AssetPack {
  id           Int                @id @default(autoincrement())
  uuid         String             @unique
  name         String
  description  String
  author       String
  version      String
  terrain      Json
  structures   Json
  objects      Json
  autotiles    Json               @default("[]")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model AvatarPack {
  id           Int                 @id @default(autoincrement())
  uuid         String              @unique
  name         String
  description  String
  author       String
  version      String
  type         String              @default("full")
  avatars      Json
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

/// v2: Deterministische Tileset-Registry pro Map
model MapTileset {
  id         String   @id @default(cuid())
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  slot       Int
  key        String
  imageUrl   String
  tileWidth  Int
  tileHeight Int
  margin     Int?
  spacing    Int?
  hash       String?
  tileCount  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([mapId, slot])
  @@index([mapId])
}

/// v2: Logische Layer pro Map (z. B. ground, walls, collision)
model MapLayer {
  id         String      @id @default(cuid())
  map        Map         @relation(fields: [mapId], references: [id])
  mapId      String
  name       String
  chunkSize  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chunks     MapChunk[]

  @@unique([mapId, name])
  @@index([mapId])
}

/// v2: Chunk-basierte Speicherung von Layer-Daten
model MapChunk {
  id        String   @id @default(cuid())
  layer     MapLayer @relation(fields: [layerId], references: [id])
  layerId   String
  x         Int
  y         Int
  version   Int
  encoding  String   // 'rle' | 'rle-bool' | 'gzip+rle'
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([layerId, x, y])
  @@index([layerId])
}

model MapObject {
  id             Int      @id @default(autoincrement())
  mapId          String
  map            Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  assetPackUuid  String
  itemId         String
  category       String   // 'structure' | 'objects'
  tileX          Int
  tileY          Int
  chunkX         Int      // floor(tileX / chunkSize)
  chunkY         Int      // floor(tileY / chunkSize)
  width          Int
  height         Int
  collide        Boolean  @default(false)
  zIndex         Int      @default(0)
  rotation       Int      @default(0)
  flipX          Boolean  @default(false)
  flipY          Boolean  @default(false)
  scaleFactor    Float    @default(1)
  dataUrl        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([mapId, chunkX, chunkY])
}

enum NpcMediaType {
  audio
  video
  screenshare
}

model Npc {
  id             String         @id @default(cuid())
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  tenantId       String
  identity       String         // unique per tenant, e.g. "npc-greeter"
  name           String         // display name
  avatarId       String         @default("default-characters:businessman1")
  spawnX         Float          @default(200)
  spawnY         Float          @default(200)
  spawnDirection String         @default("down")
  enabled        Boolean        @default(true)
  showBadge      Boolean        @default(false)
  mapName        String?        // optional: which map this NPC should spawn on
  config         Json?          // arbitrary JSON config
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  mediaFiles     NpcMediaFile[]

  @@unique([tenantId, identity])
  @@index([tenantId])
}

model NpcMediaFile {
  id          String       @id @default(cuid())
  npc         Npc          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  npcId       String
  filename    String       // original filename
  storagePath String       // path on disk relative to NPC_MEDIA_DIR
  mimeType    String
  sizeBytes   Int
  duration    Float?       // seconds, null if unknown
  mediaType   NpcMediaType
  createdAt   DateTime     @default(now())

  @@index([npcId])
}

