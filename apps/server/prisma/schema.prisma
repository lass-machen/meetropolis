generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma seed configuration (uses TS seed file)
// This is read by `prisma db seed` via package.json in the server workspace.

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  imageUrl        String?
  avatarConfig    Json?
  passwordHash    String?
  emailVerifiedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  presences       Presence[]
  passwordResets  PasswordReset[]
  apiTokens       ApiToken[]
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  createdAt DateTime @default(now())
  createdBy String?
  usedAt    DateTime?
  usedById  String?
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  name       String?
  hash       String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model Map {
  id        String   @id @default(cuid())
  name      String   @unique
  meta      Json
  // v2 Map Geometry & Settings
  width      Int?
  height     Int?
  tileWidth  Int?
  tileHeight Int?
  chunkSize  Int?     @default(32)
  version    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
  zones     Zone[]
  // v2 relations
  tilesets  MapTileset[]
  layers    MapLayer[]
}

model Room {
  id        String   @id @default(cuid())
  name      String
  map       Map      @relation(fields: [mapId], references: [id])
  mapId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zones     Zone[]
  presences Presence[]
}

model Zone {
  id         String   @id @default(cuid())
  name       String
  capacity   Int?
  polygon    Json
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Presence {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  x          Int
  y          Int
  direction  String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  
  @@index([userId, roomId])
}

model AssetPack {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique
  name        String
  description String
  author      String
  version     String
  terrain     Json
  structures  Json
  objects     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// v2: Deterministische Tileset-Registry pro Map
model MapTileset {
  id         String   @id @default(cuid())
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  slot       Int
  key        String
  imageUrl   String
  tileWidth  Int
  tileHeight Int
  margin     Int?
  spacing    Int?
  hash       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([mapId, slot])
  @@index([mapId])
}

/// v2: Logische Layer pro Map (z. B. ground, walls, collision)
model MapLayer {
  id         String      @id @default(cuid())
  map        Map         @relation(fields: [mapId], references: [id])
  mapId      String
  name       String
  chunkSize  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chunks     MapChunk[]

  @@unique([mapId, name])
  @@index([mapId])
}

/// v2: Chunk-basierte Speicherung von Layer-Daten
model MapChunk {
  id        String   @id @default(cuid())
  layer     MapLayer @relation(fields: [layerId], references: [id])
  layerId   String
  x         Int
  y         Int
  version   Int
  encoding  String   // 'rle' | 'rle-bool' | 'gzip+rle'
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([layerId, x, y])
  @@index([layerId])
}
