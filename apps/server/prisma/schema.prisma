generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma seed configuration (uses TS seed file)
// This is read by `prisma db seed` via package.json in the server workspace.

enum Role {
  owner
  admin
  member
}

model Tenant {
  id                    String       @id @default(cuid())
  slug                  String       @unique
  name                  String
  concurrentLimit       Int          @default(50)
  freeSeats             Int          @default(3)
  bypassLimits          Boolean      @default(false)
  isInternal            Boolean      @default(false)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  status                String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Trial tracking
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  trialConvertedAt      DateTime?

  // Payment failure / Dunning state
  paymentFailedAt       DateTime?
  gracePeriodEndsAt     DateTime?
  dunningStep           Int?         @default(0)
  lastDunningEmailAt    DateTime?

  // Subscription pause
  pausedAt              DateTime?
  pauseEndsAt           DateTime?
  pauseReason           String?

  memberships           Membership[]
  maps                  Map[]
  rooms                 Room[]
  zones                 Zone[]
  presences             Presence[]
  invites               Invite[]
  billingAuditLogs      BillingAuditLog[]
}

model Membership {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  role      Role     @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String?
  imageUrl            String?
  passwordHash        String?
  emailVerifiedAt     DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  presences           Presence[]
  passwordResets      PasswordReset[]
  emailVerifications  EmailVerification[]
  apiTokens           ApiToken[]
  memberships         Membership[]
  sessions            Session[]
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  createdAt DateTime @default(now())
  createdBy String?
  usedAt    DateTime?
  usedById  String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  role      Role     @default(member)
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  email     String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  name       String?
  hash       String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model Session {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  tokenHash    String    @unique
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Map {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String
  meta      Json
  // v2 Map Geometry & Settings
  width      Int?
  height     Int?
  tileWidth  Int?
  tileHeight Int?
  chunkSize  Int?     @default(32)
  version    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms     Room[]
  zones     Zone[]
  // v2 relations
  tilesets  MapTileset[]
  layers    MapLayer[]

  @@unique([tenantId, name])
}

model Room {
  id        String   @id @default(cuid())
  name      String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  map       Map      @relation(fields: [mapId], references: [id])
  mapId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  zones     Zone[]
  presences Presence[]

  @@unique([tenantId, name])
}

model Zone {
  id         String   @id @default(cuid())
  name       String
  capacity   Int?
  polygon    Json
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Presence {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  x          Int
  y          Int
  direction  String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  
  @@index([userId, roomId])
}

model AssetPack {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique
  name        String
  description String
  author      String
  version     String
  terrain     Json
  structures  Json
  objects     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// v2: Deterministische Tileset-Registry pro Map
model MapTileset {
  id         String   @id @default(cuid())
  map        Map      @relation(fields: [mapId], references: [id])
  mapId      String
  slot       Int
  key        String
  imageUrl   String
  tileWidth  Int
  tileHeight Int
  margin     Int?
  spacing    Int?
  hash       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([mapId, slot])
  @@index([mapId])
}

/// v2: Logische Layer pro Map (z. B. ground, walls, collision)
model MapLayer {
  id         String      @id @default(cuid())
  map        Map         @relation(fields: [mapId], references: [id])
  mapId      String
  name       String
  chunkSize  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chunks     MapChunk[]

  @@unique([mapId, name])
  @@index([mapId])
}

/// v2: Chunk-basierte Speicherung von Layer-Daten
model MapChunk {
  id        String   @id @default(cuid())
  layer     MapLayer @relation(fields: [layerId], references: [id])
  layerId   String
  x         Int
  y         Int
  version   Int
  encoding  String   // 'rle' | 'rle-bool' | 'gzip+rle'
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([layerId, x, y])
  @@index([layerId])
}

/// Billing audit log for tracking all billing-related events
model BillingAuditLog {
  id              String   @id @default(cuid())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String

  eventType       String   // 'payment_failed', 'dunning_email_sent', 'trial_started', etc.
  eventSource     String   // 'stripe_webhook', 'cron_job', 'api', 'manual'
  stripeEventId   String?  // Stripe event ID for deduplication

  previousValues  Json?    // Snapshot of previous state
  newValues       Json?    // Snapshot of new state

  triggeredBy     String?  // User ID or 'system'
  metadata        Json?    // Additional context

  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
  @@index([stripeEventId])
}
