{
  "name": "@meetropolis/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma generate && prisma db push",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.29",
    "colyseus": "^0.14.40",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "prisma": "^5.16.1",
    "zod": "^3.23.8",
    "@prisma/client": "^5.16.1",
    "livekit-server-sdk": "^2.7.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/debug": "^4.1.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}

