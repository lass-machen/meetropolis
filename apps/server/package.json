{
  "name": "@meetropolis/server",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "predev": "prisma generate --schema=./prisma/schema.prisma && prisma db push --schema=./prisma/schema.prisma && prisma db seed --schema=./prisma/schema.prisma",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-generated.mjs && node ./scripts/copy-catalog.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.seed.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "map:import:v2": "tsx src/scripts/importMapV2.ts",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --name init --schema=./prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema=./prisma/schema.prisma",
    "start:dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "c12": "^3.3.4",
    "colyseus": "^0.17.10",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "empathic": "^2.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "fast-check": "^4.7.0",
    "helmet": "^8.1.0",
    "jiti": "^2.7.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pathe": "^2.0.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pngjs": "^7.0.0",
    "prom-client": "^15.1.3",
    "pure-rand": "^8.4.0",
    "unzipper": "^0.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.4",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.16.0",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
