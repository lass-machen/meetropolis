{
  "name": "@meetropolis/server",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "predev": "npm run prisma:compose && prisma generate --schema=./prisma/schema.composed.prisma && prisma db push --schema=./prisma/schema.composed.prisma && prisma db seed --schema=./prisma/schema.composed.prisma",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "map:import:v2": "tsx src/scripts/importMapV2.ts",
    "prisma:compose": "node prisma/compose-schema.cjs",
    "prisma:generate": "npm run prisma:compose && prisma generate --schema=./prisma/schema.composed.prisma",
    "prisma:migrate": "npm run prisma:compose && prisma migrate dev --name init --schema=./prisma/schema.composed.prisma",
    "prisma:push": "npm run prisma:compose && prisma db push --schema=./prisma/schema.composed.prisma",
    "prisma:seed": "npm run prisma:compose && prisma db seed --schema=./prisma/schema.composed.prisma",
    "start:dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.75",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.51.0",
    "bcryptjs": "^2.4.3",
    "c12": "^3.3.4",
    "colyseus": "^0.16.5",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^16.4.5",
    "effect": "^3.21.2",
    "empathic": "^2.0.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "fast-check": "^3.23.2",
    "helmet": "^7.1.0",
    "jiti": "^2.7.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.2",
    "multer": "^2.1.1",
    "pathe": "^2.0.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "pure-rand": "^7.0.1",
    "unzipper": "^0.12.3",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
