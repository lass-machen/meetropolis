# === Defensiv: kein Font Awesome Pro mehr ins Repo ===
# Wir nutzen lucide-react. FA Pro wäre kommerziell lizenziert und darf
# nicht im OSS-Tree landen. Eintrag verhindert versehentliches Re-Adden.
apps/web/public/vendor/fontawesome/

# === Closed-source sibling repos (no longer submodules) ===
# These paths are intentionally not part of this OSS distribution.
# Loaders (apps/web/scripts/optional-submodules.ts,
# apps/server/prisma/compose-schema.cjs) resolve them at build time via
# MEETROPOLIS_{BRAND,DESKTOP,ENTERPRISE}_PATH env vars, with sibling-
# clone defaults (../meetropolis-{brand,desktop,enterprise}). When the
# paths are absent (e.g. a fresh OSS clone), the build falls back to
# OSS-only behaviour gracefully — no broken imports, no 404s.
packages/brand/
packages/desktop/
packages/tenancy-enterprise/

# === Brand-Submodule-Symlinks ===
# apps/web/optional-submodules.ts symlinkt Public-Assets aus
# packages/brand/packages/web/public/ rekursiv nach apps/web/public/.
# Diese Symlinks sind Runtime-Artefakte und gehören nicht ins OSS-Repo.
# OSS-eigene Files in apps/web/public/ bleiben getrackt; nur die vom Brand-
# Submodule beigesteuerten Pfade werden hier ignoriert.
/apps/web/public/favicon.ico
/apps/web/public/brand/README.md
/apps/web/public/brand/favicon.png
/apps/web/public/brand/logo.png
/apps/web/public/images/pub/auth-branding-pixel-art-lobby.png
/apps/web/public/images/pub/hero-product-visual-2.png
/apps/web/public/images/pub/meetropolis-editor.webm
/apps/web/public/images/pub/meetropolis-screen-2.webp
/apps/web/public/images/pub/meetropolis-screen-3.webp
/apps/web/public/images/pub/meetropolis-screen-4.webp
/apps/web/public/images/pub/meetropolis-screen-5.webp
/apps/web/public/images/pub/meetropolis-screen-hero.webp
