{
  "name": "meetropolis",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "npm --workspace=@meetropolis/web run dev",
    "dev:server": "npm --workspace=@meetropolis/server run dev",
    "lint": "node scripts/enforce-budgets.js",
    "build": "npm -w @meetropolis/web run build && npm -w @meetropolis/server run build",
    "generate": "npm -w @meetropolis/server run prisma:generate",
    "prisma:migrate": "npm -w @meetropolis/server run prisma:migrate",
    "dev:loadtest": "npm -w @meetropolis/loadtest run dev",
    "dev:desktop": "concurrently -n web,desktop \"npm:dev:web\" \"npm --workspace=@meetropolis/desktop run dev\"",
    "build:desktop": "npm -w @meetropolis/web run build && npm -w @meetropolis/desktop run build",
    "dist:desktop": "VITE_TARGET=desktop npm -w @meetropolis/web run build && npm -w @meetropolis/desktop run dist"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "pino": "^10.1.0",
    "unzipper": "^0.12.3"
  }
}
