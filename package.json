{
  "name": "meetropolis",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "npm --workspace=@meetropolis/web run dev",
    "dev:server": "npm --workspace=@meetropolis/server run dev",
    "build": "npm -w @meetropolis/web run build && npm -w @meetropolis/server run build",
    "generate": "npm -w @meetropolis/server run prisma:generate",
    "prisma:migrate": "npm -w @meetropolis/server run prisma:migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

